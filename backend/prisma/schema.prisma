// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
// schema
model User {
  id           String   @id @default(uuid())
  name         String  
  phoneNumber  String?   @unique @map("phone_number")     
  email        String   @unique
  passwordHash String   @map("password_hash")
  isVerified   Boolean  @default(false) @map("is_verified")
  otpCode     String?   @map("otp_code")
  createdAt    DateTime @default(now()) @map("created_at")

  devices      Device[]
}


enum DeviceType {
  sensor
  actuator
}

model Device {
  id               Int       @id @default(autoincrement())
  name             String
  type             DeviceType 
  unit             String?
  stateTopic       String    @map("state_topic")
  controlTopic     String?   @map("control_topic")
  connectionStatus ConnectionStatus @default(unavailable) @map("connection_status")
  lastSeen         DateTime? @map("last_seen")
  userId           String?   @map("user_id")
  user             User?     @relation(fields: [userId], references: [id])
  actuatorState    ActuatorState?
  sensorState      SensorState?
  deviceHistories  DeviceHistory[]
}

enum ConnectionStatus {
  online
  offline
  error
  unavailable
}

model ActuatorState {
  deviceId     Int      @id @map("device_id")
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  isOn         Boolean  @default(false) @map("is_on")
  intensity    Int?     @default(0)
  lastUpdated  DateTime @map("last_updated")
}

model SensorState {
  deviceId    Int      @id @map("device_id")
  device      Device   @relation(fields: [deviceId], references: [id] , onDelete: Cascade)
  value       Float
  lastUpdated DateTime @map("last_updated")
}

model DeviceHistory {
  id         Int       @id @default(autoincrement())
  deviceId   Int       @map("device_id")
  device     Device    @relation(fields: [deviceId], references: [id] , onDelete: Cascade)
  actionType ActionType @map("action_type")
  oldValue   String?   @map("old_value")
  newValue   String?   @map("new_value")
  recordedAt DateTime  @default(now()) @map("recorded_at")
}

enum ActionType {
  turned_on
  turned_off
  intensity_change
  color_change
  sensor_reading
  disconnected
  reconnected
}
